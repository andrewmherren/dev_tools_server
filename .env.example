# Dev Environment Configuration (.env)
# 
# Copy this file to .env and customize for your machine.
# DO NOT commit .env to git - it contains local paths.
# Example:  cp .env.example .env


# ============================================
# OLLAMA MODEL STORAGE PATH
# ============================================
# Ollama stores LLM models here. Models are large (GBs each),
# so point this to a drive with sufficient space.
#
# Windows (recommended: dedicated drive to avoid OS drive clutter):
OLLAMA_STORAGE_PATH=D:/ollama-models
#
# macOS (example paths - adjust to your setup):
# OLLAMA_STORAGE_PATH=/Volumes/dedicated-drive/ollama-models
# OLLAMA_STORAGE_PATH=/Users/your-user/ollama-models
#
# Linux (example paths - adjust to your dedicated drive):
# OLLAMA_STORAGE_PATH=/mnt/dedicated-drive/ollama-models
# OLLAMA_STORAGE_PATH=/home/your-user/ollama-models


# ============================================
# PROJECT WORKSPACE MOUNTS (Optional Overrides)
# ============================================
# By default, containers mount ../sandbox/my_project
# Only set these if you need a different location.
# Use absolute paths for clarity, or relative paths from dev_environment/
#
# Absolute path examples:
# PROJECT_ROOT_PATH=D:/sandbox/my_project              # Windows
# PROJECT_ROOT_PATH=/Users/username/projects/my_project  # macOS
# PROJECT_ROOT_PATH=/home/username/projects/my_project   # Linux
#
# Or relative from dev_environment/:
# PROJECT_ROOT_PATH=../sandbox/my_project
#
# Same for agents:
# AGENT_1_PATH=/full/path/to/my_project-agent-1
# AGENT_2_PATH=/full/path/to/my_project-agent-2

# ============================================
# MCP SERVER CREDENTIALS (Optional)
# ============================================
# SonarQube MCP requires authentication token
# Generate token at: https://yoursonarqube.instance/account/security/tokens
# Leave empty to disable SonarQube MCP or use localhost:9000 without auth
#
# SONARQUBE_TOKEN=your-sonarqube-token-here