{
    "name": "env-manager",
    "version": "0.1.0",
    "description": "MCP server for managing dev environment projects and agents",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "prebuild": "tsoa spec && tsoa routes",
        "build": "tsc && npm run fix:imports && npm run copy:swagger",
        "fix:imports": "node scripts/fix-imports.js",
        "copy:swagger": "node scripts/copy-swagger.js",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "sonar": "npm run test:coverage && sonar -Dsonar.host.url=http://localhost/sonarqube -Dsonar.token=$SONARQUBE_TOKEN -Dsonar.projectKey=env_manager -Dsonar.sources=src -Dsonar.inclusions=src/**/*.ts -Dsonar.exclusions=src/generated/**,**/*.config.ts -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info -Dsonar.tests=tests -Dsonar.test.inclusions=tests/**/*"
    },
    "_sonar-note": "Run in PowerShell: Set-Location D:\\sandbox\\dev_environment\\mcp-servers\\env-manager; $env:SONARQUBE_TOKEN='YOUR_TOKEN_HERE'; npm run sonar",
    "keywords": [
        "mcp",
        "docker",
        "development",
        "environment"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^0.5.0",
        "dotenv": "^16.4.5",
        "execa": "^8.0.1",
        "express": "4.18.2",
        "tsoa": "^7.0.0-alpha.0",
        "yaml": "^2.3.4",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.11.16",
        "@vitest/coverage-v8": "^1.2.2",
        "typescript": "^5.3.3",
        "vitest": "^1.2.2"
    }
}