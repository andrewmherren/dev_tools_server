{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"ToolResponse": {
				"properties": {
					"content": {
						"items": {
							"properties": {
								"text": {
									"type": "string"
								},
								"type": {
									"type": "string"
								}
							},
							"required": [
								"text",
								"type"
							],
							"type": "object"
						},
						"type": "array"
					},
					"isError": {
						"type": "boolean"
					}
				},
				"required": [
					"content"
				],
				"type": "object",
				"additionalProperties": true
			},
			"ApiResponse": {
				"properties": {
					"success": {
						"type": "boolean"
					},
					"data": {
						"$ref": "#/components/schemas/ToolResponse"
					},
					"error": {
						"type": "string"
					}
				},
				"required": [
					"success"
				],
				"type": "object",
				"additionalProperties": true
			},
			"Record_string.string_": {
				"properties": {},
				"additionalProperties": {
					"type": "string"
				},
				"type": "object",
				"description": "Construct a type with a set of properties K of type T"
			},
			"CreateProjectRequest": {
				"properties": {
					"name": {
						"type": "string"
					},
					"gitUrl": {
						"type": "string"
					},
					"image": {
						"type": "string"
					},
					"envVars": {
						"$ref": "#/components/schemas/Record_string.string_"
					},
					"confirm": {
						"type": "boolean"
					}
				},
				"required": [
					"name"
				],
				"type": "object",
				"additionalProperties": true
			},
			"DeleteProjectRequest": {
				"properties": {
					"name": {
						"type": "string"
					},
					"confirm": {
						"type": "boolean"
					}
				},
				"required": [
					"name"
				],
				"type": "object",
				"additionalProperties": true
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "env-manager",
		"version": "0.1.0",
		"description": "MCP server for managing dev environment projects and agents",
		"license": {
			"name": "MIT"
		},
		"contact": {}
	},
	"paths": {
		"/projects": {
			"post": {
				"operationId": "CreateProject",
				"responses": {
					"200": {
						"description": "Project created or preview returned",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"properties": {
												"preview": {
													"$ref": "#/components/schemas/ToolResponse"
												}
											},
											"required": [
												"preview"
											],
											"type": "object"
										},
										{
											"properties": {
												"success": {
													"$ref": "#/components/schemas/ToolResponse"
												}
											},
											"required": [
												"success"
											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"400": {
						"description": "Invalid input or project already exists",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse"
								}
							}
						}
					}
				},
				"description": "Create a new project or onboard an existing one",
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateProjectRequest"
							}
						}
					}
				}
			},
			"get": {
				"operationId": "ListProjects",
				"responses": {
					"200": {
						"description": "Projects listed successfully",
						"content": {
							"application/json": {
								"schema": {
									"properties": {
										"projects": {
											"$ref": "#/components/schemas/ToolResponse"
										}
									},
									"required": [
										"projects"
									],
									"type": "object"
								}
							}
						}
					}
				},
				"description": "List all managed projects",
				"security": [],
				"parameters": []
			}
		},
		"/projects/{name}/delete": {
			"post": {
				"operationId": "DeleteProject",
				"responses": {
					"200": {
						"description": "Project unregistered or preview returned",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"properties": {
												"preview": {
													"$ref": "#/components/schemas/ToolResponse"
												}
											},
											"required": [
												"preview"
											],
											"type": "object"
										},
										{
											"properties": {
												"success": {
													"$ref": "#/components/schemas/ToolResponse"
												}
											},
											"required": [
												"success"
											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"400": {
						"description": "Invalid project name or not found",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse"
								}
							}
						}
					}
				},
				"description": "Delete/unregister a project",
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/DeleteProjectRequest"
							}
						}
					}
				}
			}
		}
	},
	"servers": [
		{
			"url": "/"
		}
	]
}