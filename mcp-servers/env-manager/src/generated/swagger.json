{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"ToolResponse": {
				"properties": {
					"content": {
						"items": {
							"properties": {
								"text": {
									"type": "string"
								},
								"type": {
									"type": "string"
								}
							},
							"required": [
								"text",
								"type"
							],
							"type": "object"
						},
						"type": "array"
					},
					"isError": {
						"type": "boolean"
					}
				},
				"required": [
					"content"
				],
				"type": "object",
				"additionalProperties": true
			},
			"ActionResponse": {
				"properties": {
					"status": {
						"type": "string",
						"enum": [
							"preview",
							"success",
							"error"
						]
					},
					"message": {
						"type": "string"
					},
					"toolOutput": {
						"$ref": "#/components/schemas/ToolResponse"
					}
				},
				"required": [
					"status",
					"message"
				],
				"type": "object",
				"additionalProperties": true
			},
			"ApiResponse": {
				"properties": {
					"success": {
						"type": "boolean"
					},
					"data": {
						"$ref": "#/components/schemas/ToolResponse"
					},
					"error": {
						"type": "string"
					}
				},
				"required": [
					"success"
				],
				"type": "object",
				"additionalProperties": true
			},
			"Record_string.string_": {
				"properties": {},
				"additionalProperties": {
					"type": "string"
				},
				"type": "object",
				"description": "Construct a type with a set of properties K of type T"
			},
			"CreateProjectRequest": {
				"properties": {
					"name": {
						"type": "string",
						"description": "Project name (lowercase letters, numbers, hyphens, underscores).\r\nExample: \"my-app\""
					},
					"gitUrl": {
						"type": "string",
						"description": "Optional Git repository URL to clone.\r\nExample: \"https://github.com/org/repo.git\""
					},
					"image": {
						"type": "string",
						"description": "Docker image to use for the project container.\r\nExample: \"ubuntu:22.04\""
					},
					"envVars": {
						"$ref": "#/components/schemas/Record_string.string_",
						"description": "Environment variables to write into the project's .env file.\r\nExample: { \"NODE_ENV\": \"development\" }"
					},
					"confirm": {
						"type": "boolean",
						"description": "When true, applies changes. When false or omitted, returns a preview only."
					}
				},
				"required": [
					"name"
				],
				"type": "object",
				"additionalProperties": true
			},
			"AgentInfo": {
				"properties": {
					"name": {
						"type": "string"
					},
					"service": {
						"type": "string"
					},
					"container": {
						"type": "string"
					},
					"status": {
						"type": "string"
					}
				},
				"required": [
					"name",
					"service",
					"container",
					"status"
				],
				"type": "object",
				"additionalProperties": true
			},
			"ProjectInfo": {
				"properties": {
					"name": {
						"type": "string"
					},
					"path": {
						"type": "string"
					},
					"service": {
						"type": "string"
					},
					"status": {
						"type": "string"
					},
					"human_container": {
						"type": "string"
					},
					"agents": {
						"items": {
							"$ref": "#/components/schemas/AgentInfo"
						},
						"type": "array"
					}
				},
				"required": [
					"name",
					"path",
					"service",
					"status",
					"agents"
				],
				"type": "object",
				"additionalProperties": true
			},
			"ListProjectsResponse": {
				"properties": {
					"count": {
						"type": "number",
						"format": "double"
					},
					"projects": {
						"items": {
							"$ref": "#/components/schemas/ProjectInfo"
						},
						"type": "array"
					}
				},
				"required": [
					"count",
					"projects"
				],
				"type": "object",
				"additionalProperties": true
			},
			"DeleteProjectRequest": {
				"properties": {
					"name": {
						"type": "string",
						"description": "Project name to unregister.\r\nExample: \"my-app\""
					},
					"confirm": {
						"type": "boolean",
						"description": "When true, applies changes. When false or omitted, returns a preview only."
					}
				},
				"required": [
					"name"
				],
				"type": "object",
				"additionalProperties": true
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "env-manager",
		"version": "0.1.0",
		"description": "MCP server for managing dev environment projects and agents",
		"license": {
			"name": "MIT"
		},
		"contact": {}
	},
	"paths": {
		"/projects": {
			"post": {
				"operationId": "CreateProject",
				"responses": {
					"200": {
						"description": "Project created or preview returned",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ActionResponse"
								}
							}
						}
					},
					"400": {
						"description": "Invalid input or project already exists",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse"
								}
							}
						}
					}
				},
				"description": "Create a new project or onboard an existing one",
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateProjectRequest"
							}
						}
					}
				}
			},
			"get": {
				"operationId": "ListProjects",
				"responses": {
					"200": {
						"description": "Projects listed successfully",
						"content": {
							"application/json": {
								"schema": {
									"anyOf": [
										{
											"$ref": "#/components/schemas/ListProjectsResponse"
										},
										{
											"properties": {
												"error": {
													"type": "string"
												}
											},
											"required": [
												"error"
											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"400": {
						"description": "Failed to list projects",
						"content": {
							"application/json": {
								"schema": {
									"properties": {
										"error": {
											"type": "string"
										}
									},
									"required": [
										"error"
									],
									"type": "object"
								}
							}
						}
					}
				},
				"description": "List all managed projects",
				"security": [],
				"parameters": []
			}
		},
		"/projects/{name}/delete": {
			"post": {
				"operationId": "DeleteProject",
				"responses": {
					"200": {
						"description": "Project unregistered or preview returned",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ActionResponse"
								}
							}
						}
					},
					"400": {
						"description": "Invalid project name or not found",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse"
								}
							}
						}
					}
				},
				"description": "Delete/unregister a project",
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/DeleteProjectRequest"
							}
						}
					}
				}
			}
		}
	},
	"servers": [
		{
			"url": "/"
		}
	]
}