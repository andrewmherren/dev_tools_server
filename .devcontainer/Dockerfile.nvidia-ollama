FROM ollama/ollama:latest

# Ensure we're running as root to install GPU tools
USER root

# Install NVIDIA utilities (for nvidia-smi)
RUN apt-get update && \
    apt-get install -y nvidia-utils-525 nvidia-cuda-toolkit && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user (1000:1000) for running Ollama
# Check if group/user already exists before creating
RUN (getent group 1000 || groupadd -g 1000 appuser) && \
    (id -u 1000 &>/dev/null || useradd -u 1000 -g 1000 -m -d /home/ollama appuser) && \
    mkdir -p /home/ollama && \
    chown -R 1000:1000 /home/ollama

# Copy initialization script that auto-downloads required models
COPY .devcontainer/ollama-entrypoint.sh /usr/local/bin/ollama-entrypoint.sh
RUN chmod +x /usr/local/bin/ollama-entrypoint.sh

# Keep as root for Windows/NTFS compatibility with mounted volumes
# (NTFS permissions don't map to Unix users the same way)
USER root

# Expose Ollama port
EXPOSE 11434

# Use custom entrypoint to initialize models on first run
ENTRYPOINT ["/usr/local/bin/ollama-entrypoint.sh"]
