FROM node:22-slim

# Install system dependencies for Playwright Chromium
RUN apt-get update && apt-get install -y \
    libglib2.0-0 \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install docs-mcp-server globally
RUN npm install -g @arabold/docs-mcp-server

# Create non-root user (1000:1000) with data directory
# Check if group/user already exists before creating
RUN (getent group 1000 || groupadd -g 1000 appuser) && \
    (id -u 1000 &>/dev/null || useradd -u 1000 -g 1000 -m -d /data appuser) && \
    mkdir -p /data && \
    chown -R 1000:1000 /data

# Set working directory
WORKDIR /data

# Set docs-mcp-server storage path (storePath in config)
ENV DOCS_MCP_APP_STORE_PATH=/data

# Default to Ollama for embeddings if no other provider specified
# Users can override OPENAI_API_KEY in .env for other providers
ENV OPENAI_API_BASE=http://ollama:11434/v1
ENV DOCS_MCP_EMBEDDING_MODEL=llama2
ENV OPENAI_API_KEY=dummy

# Switch to non-root user
USER 1000:1000

# Expose ports
# 6280: MCP SSE endpoint
# 6281: Web UI
EXPOSE 6280 6281

# Default command: run MCP server on port 6280
# Use the globally installed package instead of npx to avoid runtime downloads
CMD ["docs-mcp-server", "--protocol", "http", "--host", "0.0.0.0", "--port", "6280", "--store-path", "/data"]
